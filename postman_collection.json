{
  "info": {
    "name": "Digital Complaint Management System",
    "description": "API collection for the Digital Complaint Management System with SLA + Notifications",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@test.com\",\n  \"password\": \"user123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var jsonData = pm.response.json();\npm.collectionVariables.set('token', jsonData.data.token);"]
            }
          }]
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register-admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@test.com\",\n  \"password\": \"admin123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var jsonData = pm.response.json();\npm.collectionVariables.set('adminToken', jsonData.data.token);"]
            }
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@test.com\",\n  \"password\": \"user123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["var jsonData = pm.response.json();\npm.collectionVariables.set('token', jsonData.data.token);"]
            }
          }]
        }
      ]
    },
    {
      "name": "Complaints (User)",
      "item": [
        {
          "name": "Raise Complaint",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/complaints",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Network Issue in Building A\",\n  \"description\": \"Internet connection has been dropping intermittently since morning. Affecting all floors.\",\n  \"category\": \"IT\",\n  \"priority\": \"HIGH\"\n}"
            }
          }
        },
        {
          "name": "Get My Complaints",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/complaints?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["complaints"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Complaint by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/complaints/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get Complaint History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/complaints/1/history",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Complaints",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/complaints?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "complaints"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Assign Complaint",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/complaints/1/assign",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assigneeId\": 2\n}"
            }
          }
        },
        {
          "name": "Update Complaint Status",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/admin/complaints/1/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RESOLVED\",\n  \"comment\": \"Issue has been fixed by the network team\"\n}"
            }
          }
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        }
      ]
    }
  ]
}
